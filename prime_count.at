# prime_count.at
# Counts prime numbers in a range using trial division

import time

limit = 1000000
count = 0

tm_start()

n = 2
while n < limit:
    is_prime = 1
    d = 2
    while d * d <= n:
        if n % d == 0:
            is_prime = 0
            break
        d += 1
    if is_prime:
        count += 1
    n += 1

elapsed = tm_elapsed()
print("Primes below {limit}: {count}")
print("Time: {elapsed}")

