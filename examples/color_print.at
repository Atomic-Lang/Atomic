#Print with automatic line break
print("this line is normal")

#Print without automatic line break.
printl("this line is ")
print("next to this")

#colorful print
print_y("yellow")
print_r("red")
print_b("blue")
print_g("green")

#Full-color print without line breaks.
printl_y("one ")
printl_r("world ")
printl_b("of ")
printl_g("color")


